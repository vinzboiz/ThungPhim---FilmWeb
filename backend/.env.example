# MySQL (giống backend-spring / schema.sql)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=thungphim

# JWT — nên đổi và giữ bí mật; khớp với jwt.secret nếu dùng chung DB với Spring
JWT_SECRET=mot-chuoi-bi-mat-dai-ngau-nhien

# Google OAuth — cùng Client ID với frontend VITE_GOOGLE_CLIENT_ID
# Authorized JavaScript origins: http://localhost:8080
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
